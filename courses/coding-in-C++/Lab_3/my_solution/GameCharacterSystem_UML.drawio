        <mxCell id="e_heal_char_friend" value="«friend»" style="dashed=1;endArrow=open;endFill=0;endSize=8;startArrow=none;html=1;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="heal" target="char" parent="1">
