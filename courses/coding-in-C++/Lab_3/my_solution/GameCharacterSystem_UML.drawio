        <!-- ==================== RELATIONSHIP NOTES ==================== -->
        <mxCell id="note_title" value="&lt;b&gt;Relationship Decisions&lt;/b&gt;" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;whiteSpace=wrap;overflow=hidden;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="840" width="940" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note_body" value="&lt;b&gt;Composition ◆ — Character → Inventory (1:1):&lt;/b&gt; Inventory is exclusively owned by Character and cannot exist independently. It is created and destroyed with its Character.&lt;br&gt;&lt;b&gt;Aggregation ◇ — Character → Weapon (0..1):&lt;/b&gt; A Weapon can exist independently (e.g., dropped on the ground). A Character equips 0 or 1 Weapons at a time.&lt;br&gt;&lt;b&gt;Inheritance — Warrior / Mage → Character:&lt;/b&gt; Both are specializations of Character, reusing hp, name, level, xp and the gainXP / levelUp logic.&lt;br&gt;&lt;b&gt;Inheritance — Thief → Warrior, Healer → Mage:&lt;/b&gt; Job classes extend their base character type with a unique skill method (steal / heal). Method chaining is enabled via the &lt;i&gt;return *this&lt;/i&gt; pattern.&lt;br&gt;&lt;b&gt;«friend» — Healer → Character:&lt;/b&gt; Healer must modify private hp without a public setter. C++ &lt;i&gt;friend&lt;/i&gt; grants Healer controlled, targeted access while preserving encapsulation for all other classes.&lt;br&gt;&lt;b&gt;Static attributes (underlined):&lt;/b&gt; MAX_LEVEL and MIN_LEVEL are class-level constants shared across all instances." style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;spacingTop=6;whiteSpace=wrap;overflow=hidden;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="864" width="940" height="156" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
